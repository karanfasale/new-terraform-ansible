<?php
echo "<html>";
echo "<head>";
echo "<title>Web Server Status</title>";
echo "<style>";
echo "body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }";
echo ".container { max-width: 800px; margin: 0 auto; background: white; padding: 20px; border-radius: 8px; }";
echo ".success { color: #28a745; }";
echo ".info { background: #e7f3ff; padding: 10px; border-left: 4px solid #2196F3; margin: 10px 0; }";
echo "</style>";
echo "</head>";
echo "<body>";
echo "<div class='container'>";

echo "<h1>🖥️ Web Server Status</h1>";
echo "<div class='info'>";
echo "<p><strong>Hostname:</strong> " . gethostname() . "</p>";
echo "<p><strong>IP Address:</strong> " . $_SERVER['SERVER_ADDR'] . "</p>";
echo "<p><strong>Time:</strong> " . date('Y-m-d H:i:s') . "</p>";
echo "</div>";

echo "<hr>";
echo "<h2>🗄️ Database Connection Test</h2>";

$db_host = "{{ db_host }}";
$db_name = "{{ db_name }}";
$db_user = "{{ db_user }}";
$db_port = "{{ db_port | default('3306') }}";
$db_password = "{{ db_password | default('') }}";

try {
    $dsn = "mysql:host=" . $db_host . ";port=" . $db_port . ";dbname=" . $db_name;
    $pdo = new PDO($dsn, $db_user, $db_password);
    
    echo "<p class='success'>✓ Database connection successful!</p>";
    echo "<div class='info'>";
    echo "<p><strong>Host:</strong> " . $db_host . "</p>";
    echo "<p><strong>Port:</strong> " . $db_port . "</p>";
    echo "<p><strong>Database:</strong> " . $db_name . "</p>";
    
    $result = $pdo->query("SELECT VERSION() as version");
    $row = $result->fetch(PDO::FETCH_ASSOC);
    echo "<p><strong>MySQL Version:</strong> " . $row['version'] . "</p>";
    echo "</div>";
} catch (PDOException $e) {
    echo "<p style='color: red;'>✗ Database connection failed!</p>";
    echo "<p>Error: " . htmlspecialchars($e->getMessage()) . "</p>";
}

echo "</div>";
echo "</body>";
echo "</html>";
?>

